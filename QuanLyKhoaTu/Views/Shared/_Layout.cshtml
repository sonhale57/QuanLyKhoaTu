</head>
<body class="">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg position-absolute top-0 z-index-3 w-100 shadow-none my-3 navbar-transparent mt-4">
        <div class="container">
            <a class="navbar-brand font-weight-bolder ms-lg-0 ms-3 text-white" href="#">
                <img src="~/assets/client/images/logocvd.png" alt="Logo" style="width:45px;" class="rounded-pill">
                <img src="~/assets/client/images/logo-ban-van-hoa.png" alt="Logo" style="width:50px;" class="rounded-pill">
            </a>
            <button class="navbar-toggler shadow-none ms-2" type="button" data-bs-toggle="collapse" data-bs-target="#navigation" aria-controls="navigation" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon mt-2">
                    <span class="navbar-toggler-bar bar1"></span>
                    <span class="navbar-toggler-bar bar2"></span>
                    <span class="navbar-toggler-bar bar3"></span>
                </span>
            </button>
            <div class="collapse navbar-collapse" id="navigation">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center me-2 active" aria-current="page" href="#gioithieu">
                            <i class="fa fa-chart-pie opacity-6  me-1"></i>
                            Giới thiệu
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link me-2" href="#noibat">
                            <i class="fa fa-user opacity-6  me-1"></i>
                            Hoạt động nổi bật
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link me-2" href="#">
                            <i class="fa fa-user opacity-6  me-1"></i>
                            Hỉnh ảnh
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link me-2" href="#dangky">
                            <i class="fas fa-user-circle opacity-6  me-1"></i>
                            Đăng ký
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item ">
                        <a href="javascript:ModalTracuu();" class="btn btn-sm mb-0 bg-gradient-success me-2 mx-2"><i class="icon-search"></i> Tra cứu thông tin</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <!-- End Navbar -->

    <main class="main-content">
        @RenderBody()
    </main>
    <hr class="horizontal dark mt-3 ">
    <footer class="footer py-3">
        <div class="container">
            <div class="row">
                <div class="col-12 ">
                    <ul class="nav nav-footer justify-content-center">
                        <li class="nav-item">
                            <a href="https://facebook.com/banvanhoavanduc" class="nav-link text-primary font-weight-bolder" target="_blank"><i class="icon-facebook-official"></i> Follow Us</a>
                        </li>
                        <li class="nav-item">
                            <a href="mailto:sonhale57@gmail.com" class="nav-link text-secondary font-weight-bolder" target="_blank"><i class="icon-mail_outline"></i> Contact </a>
                        </li>
                        <li class="nav-item">
                            <a href="#license" class="nav-link pe-0 text-secondary font-weight-bolder" target="_blank">License</a>
                        </li>
                    </ul>
                </div>
                <div class="col-8 mx-auto text-center mt-1">
                    <p class="mb-0 text-secondary">
