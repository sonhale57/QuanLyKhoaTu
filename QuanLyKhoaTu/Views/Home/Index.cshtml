@{
    ViewBag.Title = "Khóa Tu Tuổi Trẻ";
}
<!--SECTION GIOITHIEU-->
<div class="hero align-items-start min-vh-100  pt-5 pb-5 ">
    <div class="img-bg rellax">
        <img src="~/assets/client/images/header2.png" alt="Image" class="img-fluid" width="100%">
    </div>
    <div class="container">
        <div class="row align-items-center justify-content-start mt-8">
            <div class="col-lg-5">
