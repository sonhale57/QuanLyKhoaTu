@model IEnumerable<QuanLyKhoaTu.Models.TuSinh>

@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-lg-12">
        <div class="card border-0 shadow mb-4">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-centered table-nowrap mb-0 rounded">
                        <thead class="thead-light">
                            <tr>
                                <th class="border-0 rounded-start">Người dùng</th>
                                <th class="border-0">Số điện thoại</th>
                                <th class="border-0">Email </th>
                                <th class="border-0">Tài khoản</th>
                                <th class="border-0 rounded-end">..</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex px-2 py-1">
                                            <div>
                                                @if(item.Hinhanh !=""){
                                                }
                                                else{
                                                <img src="@Html.DisplayFor(modelItem => item.Hinhanh)" class="avatar avatar-sm me-3" alt="user1">
                                                }
                                            </div>
                                            <div class="d-flex flex-column justify-content-center">
                                                <h6 class="mb-0 text-sm">@Html.DisplayFor(modelItem => item.Hoten)</h6>
                                                <p class="text-xs text-secondary mb-0">@Html.DisplayFor(modelItem => item.Phapdanh)</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <h6 class="mb-0 text-sm">@Html.DisplayFor(modelItem => item.Gioitinh)</h6>
                                    </td>
                                    <td>
                                        <h6 class="mb-0 text-sm">@item.Namsinh.Value.ToShortDateString()</h6>
                                    </td>
                                    <td>
                                        <h6 class="mb-0 text-sm">@Html.DisplayFor(modelItem => item.CMND)</h6>
                                    </td>
                                    <td>
                                        <h6 class="mb-0 text-sm">@Html.DisplayFor(modelItem => item.Email)</h6>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column justify-content-center">
                                            <h6 class="mb-0 text-sm">@Html.DisplayFor(modelItem => item.SDT)</h6>
                                            <p class="text-xs text-secondary mb-0">Người thân: @Html.DisplayFor(modelItem => item.SDT_nguoithan)</p>
                                        </div>
                                    </td>
                                    <td>
                                        <a href="/Admin/Users/Edit/@item.id" class="btn btn-sm btn-info"><i class="fa fa-pencil-square"></i> </a>
                                        <a href="javascript:Del(@item.id)" class="btn btn-sm btn-danger"><i class="fa fa-trash"></i> </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>