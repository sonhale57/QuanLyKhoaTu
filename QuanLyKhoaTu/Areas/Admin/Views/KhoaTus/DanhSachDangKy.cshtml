@{
    ViewBag.Title = "Danh sách đăng ký";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<div class="row">
    <div class="col-lg-12">
        <div class="card border-0 shadow mb-4">
            <div class="card-body">
                <div class="row">
                    <div class="col-lg-4 px-0 mx-1">
                        <div class="col-auto">
                            @Html.DropDownList("IdKhoaTu", null, htmlAttributes: new { @class = "form-control" })
                        </div>
                    </div>
                    <div class="col-lg-2 mx-0 px-0">
                        <a href="javascript:Loadlist();" class="btn btn-success"><i class="fa fa-search"></i></a>
                    </div>
                </div>
                <hr class="horizontal dark">
                <div class="table-responsive">
                    <table class="table table-centered table-nowrap mb-0 rounded">
                        <tbody id="showlist">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script type="text/javascript">
    Loadlist();
    function Loadlist() {
        $.ajax({
            url:'@Url.Action("GetDanhSach")' ,
            type: "GET",
            data: {
                   id :$("#IdKhoaTu").val()
            }
            , dataType: "json",
            success: function (data) {
                var items = '';
                var str = "";
                $.each(data, function (i, item) {
                    var rows = "<tr>"
                        + "<td>" + item.Ten + "</td>"
                        + "<td>" + item.Hoten + "</td>"
                        + "<td>" + item.Phapdanh + "</td>"
                        + "<td>" + item.Gioitinh + "</td>"
                        + "<td>" + item.SDT + "</td>"
                        + "<td>" + item.Email + "</td>"
                        + "<td>" + item.Thoigian  + "</td>"
                        + "<td>" + item.DiChuyen + "</td>"
                        + "<td>" + (item.StatusCheckin ==null? "Chưa checkin":"Đã checkin") + "</td>"
                        + "</tr>";
                    str += rows;
                });
                $('#showlist').html(str);
            },
            error: function () {
                alert('Lỗi!');
            }
        });
        return false;
    }
</script>